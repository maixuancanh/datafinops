# Local deterministic development only. Never place production credentials here.
NODE_ENV=development
DATAFINOPS_SERVICE_NAME=datafinops-local
DATAFINOPS_MODE=sandbox
DATAFINOPS_FIXED_CLOCK=2026-08-01T12:00:00.000Z
DATAFINOPS_LIVE_WRITE=false

POSTGRES_DB=datafinops
POSTGRES_USER=datafinops
POSTGRES_PASSWORD=datafinops-local-only
POSTGRES_PORT=55432
DATABASE_URL=postgresql://datafinops:datafinops-local-only@127.0.0.1:55432/datafinops

REDIS_PORT=56379
REDIS_URL=redis://127.0.0.1:56379

MINIO_ROOT_USER=datafinops-local
MINIO_ROOT_PASSWORD=datafinops-local-password
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
S3_ENDPOINT=http://127.0.0.1:59000
S3_BUCKET=datafinops-local-evidence

# Synthetic, unfunded public references only.
TXLINE_ADAPTER_MODE=replay
TXLINE_NETWORK=txline-sandbox
TXLINE_PROGRAM_ID=TxLINEProgram11111111111111111111111111
TXLINE_PUBLIC_WALLET_REF=DemoWallet111111111111111111111111111111
